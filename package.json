{
  "name": "sabio",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && cargo run --manifest-path server/Cargo.toml",
    "build": "vite build && cargo build --manifest-path server/Cargo.toml --release",
    "dist": "./build.sh",
    "start": "node scripts/start.mjs",
    "check": "tsc --noEmit && cargo check --manifest-path server/Cargo.toml"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
